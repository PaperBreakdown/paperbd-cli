{
  "name": "paperbd",
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "postinstall": "node postinstall.cjs"
  },
  "bin": {
    "paperbd": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PaperBreakdown/paperbd-cli.git"
  },
  "files": [
    "dist",
    "postinstall.cjs",
    "README.md",
    "LICENSE"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "open": "^10.2.0",
    "picocolors": "^1.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
