{
  "name": "paperbd-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "check": "tsc --noEmit",
    "build": "bun run build.ts",
    "build:local": "bun run build.ts bun-darwin-arm64",
    "build:release": "bun run build.ts bun-darwin-arm64 bun-darwin-x64 bun-linux-x64 bun-windows-x64"
  },
  "dependencies": {
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "open": "^10.2.0",
    "picocolors": "^1.1.1",
    "react": "^19.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.1",
    "typescript": "^5.9.2"
  }
}
